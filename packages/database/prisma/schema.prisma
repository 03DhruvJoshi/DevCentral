generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model Project {
  name      String
  createdAt DateTime @default(now())
  id        Int      @id @default(autoincrement())
}

model Template {
  title       String
  description String
  categoryName String
  yaml        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  id          Int      @id @default(autoincrement())
  category Category @relation(fields: [categoryName], references: [name])
}

model Category {
  name String @unique
  id   Int @id @default(autoincrement())
  templates Template[]
}

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  name              String
  passwordHash      String
  githubUsername    String?
  githubAccessToken String?
  emailVerified     Boolean  @default(false)
  role              String   @default("DEV") // "DEV" or "ADMIN"
  status            String   @default("ACTIVE") // "ACTIVE", "SUSPENDED"
  dashboardPreferences Json?
  createdAt         DateTime @default(now())
  authTokens        AuthToken[]
}

enum AuthTokenType {
  EMAIL_VERIFY
  PASSWORD_RESET
}

model AuthToken {
  id         Int           @id @default(autoincrement())
  userId     String
  tokenHash  String
  type       AuthTokenType
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime      @default(now())
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([tokenHash, type])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String
  actorEmail String
  targetId  String?
  details   Json?
  role           String?
  createdAt DateTime @default(now())
}

model PlatformConfig {
  key  String @id
  value String
  description String?
  updatedAt DateTime @updatedAt
}

